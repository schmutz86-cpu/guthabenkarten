# Environment Variables Template
# Copy this file to .env.local and fill in the values

# ===========================================
# STRIPE (Payment Processing)
# ===========================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# For testing, use test mode keys:
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===========================================
# RELOADLY (Gift Card Fulfillment)
# ===========================================
# Production credentials
RELOADLY_CLIENT_ID=your_production_client_id
RELOADLY_CLIENT_SECRET=your_production_client_secret
RELOADLY_ENV=production

# Sandbox credentials (for testing)
RELOADLY_SANDBOX_CLIENT_ID=your_sandbox_client_id
RELOADLY_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# ===========================================
# EMAIL (SMTP for order confirmations)
# ===========================================
SMTP_HOST=asmtp.mail.hostpoint.ch
SMTP_PORT=587
SMTP_USER=info@guthabenkarten.ch
SMTP_PASS=your_smtp_password
ADMIN_EMAIL=admin@guthabenkarten.ch

# Email webhook secret (for secure email processing)
EMAIL_WEBHOOK_SECRET=your_random_secret_here

# ===========================================
# SITE CONFIGURATION
# ===========================================
# Automatically detected from hostname, but can be overridden
# NEXT_PUBLIC_SITE_URL=https://guthabenkarten.ch
# NEXT_PUBLIC_SITE_NAME=Guthabenkarten.ch

# ===========================================
# OPTIONAL: Analytics & Monitoring
# ===========================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ===========================================
# OPTIONAL: Supplier APIs (when approved)
# ===========================================
# TILLO_API_KEY=xxx
# TILLO_SECRET=xxx
# RUNA_API_KEY=xxx
# ENEBA_API_KEY=xxx
# CODESWHOLESALE_API_KEY=xxx
# PREPAIDFORGE_API_KEY=xxx

# ===========================================
# DEVELOPMENT
# ===========================================
NODE_ENV=development
# NEXT_TELEMETRY_DISABLED=1
